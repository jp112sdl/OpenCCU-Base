<?xml version="1.0" encoding="utf-8"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  
  <!-- ParamsetDefs -->
  <xsd:complexType name="ParamsetDefs">
    <xsd:annotation>
      <xsd:documentation>Definitionen für Parametersätze</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="paramset" type="Paramset" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  
  <!-- Frames.Frame.Parameter.TypeAttribute -->
  <xsd:simpleType name="Frames.Frame.Parameter.TypeAttribute">
    <xsd:annotation>
      <xsd:documentation>Typ des Parameters</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="integer" />
      <xsd:enumeration value="string" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Frames.Frame.Parameter -->
  <xsd:complexType name="Frames.Frame.Parameter">
    <xsd:annotation>
      <xsd:documentation>Parameter des Datenrahmens</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="type" type="Frames.Frame.Parameter.TypeAttribute" use="required" />

    <xsd:attribute name="index" type="xsd:decimal" use="optional">
      <xsd:annotation>
        <xsd:documentation>Index des Parameters</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="size" type="xsd:decimal" use="optional">
      <xsd:annotation>
        <xsd:documentation>Größe des Parameters</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="const_value" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Konstanter Wert</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="param" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Parameter</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="signed" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="omit_if" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="PARAM" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Frames.Frame.DirectionAttribute -->
  <xsd:simpleType name="Frames.Frame.DirectionAttribute">
    <xsd:annotation>
      <xsd:documentation>Richtung des Datenrahmens</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="to_device" />
      <xsd:enumeration value="from_device" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Frames.Frame -->
  <xsd:complexType name="Frames.Frame">
    <xsd:annotation>
      <xsd:documentation>Datenrahmen</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="parameter" type="Frames.Frame.Parameter" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>

    <xsd:attribute name="id" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Id des Parameters</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="direction" type="Frames.Frame.DirectionAttribute" use="required" />

    <xsd:attribute name="type" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Typ des Parameters</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="channel_field" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="receiver_channel_field" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="event" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>Legt fest, ob der Datenrahmen ein Ereignis ist</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="allowed_receivers" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="fixed_channel" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="subtype" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="subtype_index" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Frames -->
  <xsd:complexType name="Frames">
    <xsd:annotation>
      <xsd:documentation>Liste der Datenrahmen</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="frame" type="Frames.Frame" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  
  <!-- Channels.Channel.LinkRoles.NameAttribute -->
  <xsd:simpleType name="Channels.Channel.LinkRoles.NameAttribute">
    <xsd:annotation>
      <xsd:documentation>Name der Rolle</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="SWITCH" />
      <xsd:enumeration value="WEATHER_CS" />
      <xsd:enumeration value="WEATHER_T" />
      <xsd:enumeration value="WEATHER_TH" />
      <xsd:enumeration value="WEATHER_THP" />
      <xsd:enumeration value="KEYMATIC" />
      <xsd:enumeration value="WINMATIC" />
      <xsd:enumeration value="CLIMATECONTROL_TC" />
      <xsd:enumeration value="WINDOW_SWITCH_RECEIVER" />
      <xsd:enumeration value="WINDOW_SWITCH_RECEIVER_V2" />
      <xsd:enumeration value="SMOKE_DETECTOR_TEAM" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Channels.Channel.LinkRoles.Source -->
  <xsd:complexType name="Channels.Channel.LinkRoles.Source">
    <xsd:annotation>
      <xsd:documentation>Rolle, die der Kanal als Sender einnehmen kann</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="name" type="Channels.Channel.LinkRoles.NameAttribute" use="required" />

    <xsd:attribute name="team" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="virtual" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Channels.Channel.LinkRoles.Target -->
  <xsd:complexType name="Channels.Channel.LinkRoles.Target">
    <xsd:annotation>
      <xsd:documentation>Rolle, die der Kanal als Empfänger einnehmen kann</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="name" type="Channels.Channel.LinkRoles.NameAttribute" use="required" />

    <xsd:attribute name="team" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="virtual" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Channels.Channel.LinkRoles -->
  <xsd:complexType name="Channels.Channel.LinkRoles">
    <xsd:annotation>
      <xsd:documentation>Rollen, die der Kanal in der Verknüpfung annehmen kann.</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="source" type="Channels.Channel.LinkRoles.Source" minOccurs="0" maxOccurs="unbounded" />
      <xsd:element name="target" type="Channels.Channel.LinkRoles.Target" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  
  <!-- Channels.Channel.EnforceLink.Value -->
  <xsd:complexType name="Channels.Channel.EnforceLink.Value">
    <xsd:annotation>
      <xsd:documentation>???</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="id" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="value" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Channels.Channel.EnforceLink -->
  <xsd:complexType name="Channels.Channel.EnforceLink">
    <xsd:annotation>
      <xsd:documentation>???</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="value" type="Channels.Channel.EnforceLink.Value" minOccurs="1" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  
  <!-- Channels.Channel.UIFlagsAttribute -->
  <xsd:simpleType name="Channels.Channel.UIFlagsAttribute">
    <xsd:annotation>
      <xsd:documentation>UI Flags</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="internal" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Channels.Channel -->
  <xsd:complexType name="Channels.Channel">
    <xsd:annotation>
      <xsd:documentation>Kanal</xsd:documentation>
    </xsd:annotation>

    <xsd:choice minOccurs="0" maxOccurs="unbounded">
      <xsd:element name="description" type="Description" />
      <xsd:element name="docu" type="Paramset.Parameter.Docu" />
      <xsd:element name="link_roles" type="Channels.Channel.LinkRoles" />
      <xsd:element name="special_parameter" type="Paramset.Parameter"  />
      <xsd:element name="paramset" type="Paramset" />
      <xsd:element name="subconfig" type="Channels.Channel" />
      <xsd:element name="enforce_link" type="Channels.Channel.EnforceLink" />
    </xsd:choice>

    <xsd:attribute name="index" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Index des Kanals</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="type" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Kanaltyp</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="ui_flags" type="Channels.Channel.UIFlagsAttribute" use="optional" />

    <xsd:attribute name="class" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Klasse des Kanals</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="count" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Anzahl der Kanäle</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="hidden" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>Legt fest, ob der Kanal versteckt ist.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="physical_index_offset" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Offset des physischen Wertes</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="autoregister" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="pair_function" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="function" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="paired" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>Gibt an, ob der Kanal Teil einer Gruppe ist</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="aes_default" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>Legt die AES-Einstellung fest</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="count_from_sysinfo" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Ermittelt die Anzahl der Kanäle aus dem SysInfo-Telegramm</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="direction" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="aes_always" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="has_team" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="team_tag" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Channels -->
  <xsd:complexType name="Channels">
    <xsd:annotation>
      <xsd:documentation>Kanäle</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="channel" type="Channels.Channel" minOccurs="1" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>
  
  <!-- Paramset.Parameter.Conversion.Code.ScopeAttribute -->
  <xsd:simpleType name="Paramset.Parameter.Conversion.Code.ScopeAttribute">
    <xsd:annotation>
      <xsd:documentation>Geltungsbereich des Codes</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="l2p" />
      <xsd:enumeration value="p2l" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Paramset.Parameter.Conversion.Code -->
  <xsd:complexType name="Paramset.Parameter.Conversion.Code">
    <xsd:annotation>
      <xsd:documentation>Tcl-Script zur Konvertierung (veraltet)</xsd:documentation>
    </xsd:annotation>

    <xsd:simpleContent>
      <xsd:extension base="xsd:string">
        <xsd:attribute name="scope" type="Paramset.Parameter.Conversion.Code.ScopeAttribute" use="required" />
      </xsd:extension>
    </xsd:simpleContent>
  </xsd:complexType>
  
  <!-- Paramset.Parameter.Conversion.ValueMap -->
  <xsd:complexType name="Paramset.Parameter.Conversion.ValueMap">
    <xsd:annotation>
      <xsd:documentation>???</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="device_value" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="parameter_value" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="mask" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="from_device" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="to_device" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Paramset.Parameter.Conversion.TypeAttribute -->
  <xsd:simpleType name="Paramset.Parameter.Conversion.TypeAttribute">
    <xsd:annotation>
      <xsd:documentation>Typ der Kovertierung</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="integer_integer_map" />
      <xsd:enumeration value="float_configtime" />
      <xsd:enumeration value="float_integer_scale" />
      <xsd:enumeration value="boolean_integer" />
      <xsd:enumeration value="action_key_counter" />
      <xsd:enumeration value="option_integer" />
      <xsd:enumeration value="integer_integer_scale" />
      <xsd:enumeration value="integer_tinyfloat" />
      <xsd:enumeration value="rc19display" />
      <xsd:enumeration value="toggle" />
      <xsd:enumeration value="blind_test" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Paramset.Parameter.Conversion -->
  <xsd:complexType name="Paramset.Parameter.Conversion">
    <xsd:annotation>
      <xsd:documentation>Kovertierung</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="code" type="Paramset.Parameter.Conversion.Code" minOccurs="0" maxOccurs="2"/>
      <xsd:element name="value_map" type="Paramset.Parameter.Conversion.ValueMap" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
    
    <xsd:attribute name="type" type="Paramset.Parameter.Conversion.TypeAttribute" use="required" />

    <xsd:attribute name="factors" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="value_size" type="xsd:decimal" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="factor" type="xsd:decimal" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="offset" type="xsd:decimal" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="invert" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="sim_counter" type="xsd:string" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="counter_size" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="threshold" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="false" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="true" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="div" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="mul" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>???</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="mantissa_start" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Start der Mantisse</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="mantissa_size" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Größe der Mantisse</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="exponent_start" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Start des Exponenten</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="exponent_size" type="xsd:int" use="optional">
      <xsd:annotation>
        <xsd:documentation>Größe des Exponenten</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
   </xsd:complexType>
  
  <!-- Paramset.Parameter.Physical.Get -->
  <xsd:complexType name="Paramset.Parameter.Physical.Get">
    <xsd:annotation>
      <xsd:documentation>Liest den Parameter</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="request" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Id des Anfrage-Datenrahmens</xsd:documentation>
