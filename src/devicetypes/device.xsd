    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Description.Field -->
  <xsd:complexType name="Description.Field">
    <xsd:annotation>
      <xsd:documentation>Spezifiziert ein einzelnes Name-Wert-Paar innerhalb einer Description</xsd:documentation>
    </xsd:annotation>

    <xsd:attribute name="id" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Name.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="value" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Wer.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="type" type="Description.Field.TypeAttribute" default="string" use="optional">
      <xsd:annotation>
        <xsd:documentation>Typ für die Interpretation von value.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>

  <!-- Description -->
  <xsd:complexType name="Description">
    <xsd:annotation>
      <xsd:documentation>Parameter-Beschreibung</xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:element name="field" type="Description.Field" />
    </xsd:sequence>
  </xsd:complexType>

  <!-- Device.ClassAttribute -->
  <xsd:simpleType name="Device.ClassAttribute">
    <xsd:annotation>
      <xsd:documentation>Verwendung einer besonderen C++-Klasse für das Geräte anstatt HS485Device bzw. RFDevice. centeral für RFCenteral bzw HS485Central.</xsd:documentation>
    </xsd:annotation>

    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="central"></xsd:enumeration>
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Device.UIFlagsAttribute -->  
  <xsd:simpleType name="Device.UIFlagsAttribute">
    <xsd:annotation>
      <xsd:documentation>
        dontdelete: Gerät kann über die Oberfläche nicht gelöscht werden
      </xsd:documentation>
    </xsd:annotation>
    
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="dontdelete" />
    </xsd:restriction>
  </xsd:simpleType>
  
  <!-- Device -->
  <xsd:complexType name="Device">
    <xsd:annotation>
      <xsd:documentation>Root-Knoten der Gerätebeschreibung</xsd:documentation>
    </xsd:annotation>

    <xsd:choice minOccurs="1" maxOccurs="unbounded">
      <xsd:element name="docu" type="Docu" />
      <xsd:element name="supported_types" type="SupportetTypes" />
      <xsd:element name="paramset" type="Paramset" />
      <xsd:element name="channels" type="Channels" />
      <xsd:element name="frames" type="Frames"  />
      <xsd:element name="paramset_defs" type="ParamsetDefs" />
      <xsd:element name="team" type="Device" />
      <xsd:element name="description" type="Description" />
    </xsd:choice>

    <xsd:attribute name="version" type="xsd:int" default="0" use="optional">
      <xsd:annotation>
        <xsd:documentation>Version der XML-Datei. Muss hochgezählt werden, damit Änderungen an die Logikschicht weitergegeben werden.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="ui_flags" type="Device.UIFlagsAttribute" use="optional" />

    <xsd:attribute name="supports_aes" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>Gibt an, obdas Gerät AES unterstützt.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="cyclic_timeout" type="xsd:int" default="0" use="optional">
      <xsd:annotation>
        <xsd:documentation>Zeit in Sekunden, nach der sich das Gerät auf UNREACH geht, wenn keine Nachricht empfangen wurde.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="unreach_ceck_aes" type="xsd:boolean" default="false" use="optional">
      <xsd:annotation>
        <xsd:documentation>Beit true werden nur AES-authentifizierte Nachrichten für zyklische Meldungen akzeptiert.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="class" type="Device.ClassAttribute" use="optional" />

    <xsd:attribute name="rx_modes" type="xsd:string" default="ALWAYS" use="optional">
      <xsd:annotation>
        <xsd:documentation>
          Komma-separierte Liste aus ALWAYS, BURST, CONFIG, WAKEUP.
          ALWAYS: Always-On.
          BURST: Wake-On-Radio.
          CONFIG: Nach Senden der SysInfo.
          WAKEUP: Nach Aussendung mit gesetzem Wake-Me-Up-Bit.
        </xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="eep_size" type="xsd:int" default="0" use="optional">
      <xsd:annotation>
        <xsd:documentation>Größe in Byes des Geräte-EEProms</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="has_serial" type="xsd:boolean" default="true" use="optional">
      <xsd:annotation>
        <xsd:documentation>Gibt an, ob das Gerät eine abfragbare HomeMatic-Seriennummer besitzt. Bei false wird eine Seriennummer aus der HS485-Adresse erzeugt.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="peering_sysinfo_expect_channel" type="xsd:boolean" use="optional">
      <xsd:annotation>
        <xsd:documentation>Undokumentiert</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>
  
  <!-- Root-Element -->
  <xsd:element name="device" type="Device" />
  
</xsd:schema>