  <!-- Docu -->
  <xsd:complexType name="Docu" mixed="true">
    <xsd:annotation>
      <xsd:documentation>
        Allgemeine Dokumentation der Gerätefamilie.
        Das docu-Tag wird zum automatischen Erstellen der Dokumentation verwendet. Es enthält die allgemeine Dokumentation
        für die gesamte Gerätefamilie. Grundsätzlich ist dasa Tag optional und muss nicht zwingend in einer XML-Datei enthalten sein.
        Um eine sinnvolle Darstellung der automatisch erzeugten Dokumentaiton zu gewährleisten sollte es jedoch immer angegeben werden.
        Während des Build-Prozesses der HomeMatic Zentrale wird das docu-Tag aus der entsprechenden XML-Datei enfernt. Die XML-Dateien, 
        die auf der HomeMatic Zentrale liegen, enthalten diese Informationen demnach nicht mehr.
      </xsd:documentation>
    </xsd:annotation>

    <xsd:sequence>
      <xsd:any minOccurs="0" maxOccurs="unbounded" processContents="skip"/>
    </xsd:sequence>

    <xsd:attribute name="brief" type="xsd:string" default="Unbekannte Gerätefamilie" use="optional">
      <xsd:annotation>
        <xsd:documentation>Bezeichnung der Gerätefamilie.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="target" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>
          Legt fest, für welches Dokument die Dokumentation verwendet wird.
          Der Wert ist eine Kommaseparierte Liste aus folgenden Werten;
          <ul>
            <li>internal: interne Dokumentation</li>
            <li>oem: Dokumentation für Firmenkunden</li>
            <li>user: Endbenutzer-Dokumentation</li>
          </ul>
        </xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="developer" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Name des zuständigen Geräte-Entwicklers.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="developer_email" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>E-Mail-Adresse des zuständigen Geräte-Entwicklers.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>

    <xsd:attribute name="developer_telephone_number" type="xsd:string" use="required">
      <xsd:annotation>
        <xsd:documentation>Telefon-Durchwahl des zuständigen Geräte-Entwicklers.</xsd:documentation>
      </xsd:annotation>
    </xsd:attribute>
  </xsd:complexType>

