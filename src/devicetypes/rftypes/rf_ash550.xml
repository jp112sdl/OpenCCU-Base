    <type name="HM-WDS20-TH-O" id="HM-WDS20-TH-O">
      <parameter index="10.0" size="2.0" const_value="0x3C"/>
    </type>    
    <type name="HM-WDS40-TH-I" id="HM-WDS40-TH-I">
      <parameter index="10.0" size="2.0" const_value="0x3F"/>
    </type>
	<type name="HM-WDS40-TH-I Schueco" id="263 157">
      <parameter index="10.0" size="2.0" const_value="0x94"/>
