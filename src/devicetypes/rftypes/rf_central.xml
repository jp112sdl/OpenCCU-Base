<?xml version="1.0" encoding="iso-8859-1"?>
<?xml-stylesheet type="text/xsl" href="device.xsl"?>
<device version="6" class="central" ui_flags="dontdelete" >

<docu brief="HomeMatic Zentrale und virtuelle Fernbedienung" target="internal,user,oem" developer="Thole, Werner" developer_email="heiko.thole@entwicklung.eq-3.de, falk.werner@entwicklung.eq-3.de" developer_telephone_number="747, 752">
</docu>

<supported_types>
  <type name="Virtual Remote Control 50 Keys" id="CENTRAL"></type>
  <type name="Virtual Remote Control 50 Keys" id="HM-RCV-50"></type>
</supported_types>
  
<paramset type="MASTER" id="rf_central_dev_master">
</paramset>
      
<channels>

  <channel index="0" type="MAINTENANCE" ui_flags="internal" class="maintenance" count="1">

		<docu brief="Wartungskanal">
		</docu>

		<paramset type="MASTER" id="rf_central_maint_ch_master">
			<parameter id="AES_KEY" operations="read" ui_flags="invisible">
				<docu brief="???">
					???
				</docu>
         <logical type="integer"/>
        <physical type="integer" interface="internal" value_id="AES_KEY"/>
      </parameter>
    </paramset>
		
    <paramset type="VALUES" id="rf_central_maint_ch_values">
      <parameter id="INSTALL_MODE" operations="read,write">
				<docu brief="???">
				</docu>
        <logical type="boolean" default="false"/>
        <physical type="integer" interface="internal" value_id="INSTALL_MODE"/>
      </parameter>
    </paramset>
  </channel>
	
  <channel index="1" type="VIRTUAL_KEY" count="50" direction="sender">

		<docu brief="Virtuelle Taste">
		</docu>

		<link_roles>
      <source name="SWITCH"/>
      <source name="KEYMATIC"/>
      <source name="WINMATIC"/>
      <source name="REMOTECONTROL_RECEIVER"/>
    </link_roles>
		
    <paramset type="MASTER" id="rf_central_ch_virtkey_master"></paramset>

		<paramset type="VALUES" id="rf_central_ch_virtkey_values">
      <parameter id="PRESS_LONG" operations="write,event" loopback="true" control="BUTTON.LONG">
				<docu brief="Langer Tastendruck">
					Meldet einen langen Tastendruck oder löst diesen aus.
				</docu>
        <logical type="action"/>
        <physical type="integer" interface="central_command" counter="SWITCH_COUNTER">
            <set request="KEY_SIM_LONG"/>
        </physical>
      </parameter>
			
      <parameter id="PRESS_SHORT" operations="write,event" loopback="true" control="BUTTON.SHORT">
				<docu brief="Kurzer Tastendruck">
					Meldet einen kurzen Tastendruck oder löst diesen aus.
				</docu>
        <logical type="action"/>
        <physical type="integer" interface="central_command" counter="SWITCH_COUNTER">
            <set request="KEY_SIM_SHORT"/>
        </physical>
      </parameter>
			
      <parameter id="LEVEL" operations="write" control="NONE">
				<docu brief="???">
					???
				</docu>
        <logical type="float" min="0.0" max="1.0" default="0.0" unit="100%"/>
        <physical type="integer" interface="central_command" counter="SWITCH_COUNTER" value_id="LEVEL">
            <set request="SWITCH_LEVEL"/>
        </physical>
        <conversion type="float_integer_scale" factor="200"/>
      </parameter>
<!--			
      <_parameter id="CONDITION" operations="read,write">
				<docu brief="???">
					???
				</docu>
        <logical type="integer" default="0" min="0" max="255"/>
        <physical type="integer" interface="central_command" counter="SWITCH_COUNTER" value_id="CONDITION">
            <set request="SWITCH_COND"/>
        </physical>
      </_parameter>
-->      
    </paramset>
		
    <paramset type="LINK" id="rf_central_ch_virtkey_link"></paramset>
  </channel>
    
  <channel index="63" type="LISTENER" count="1" hidden="true">
	
		<docu brief="Senke für Zentralenprogramme">
			Fall in einem Zentralen-Programm z.B. ein Tastendruck auf einer
			Fernbedienung ausgewertet werden soll, wird der entsprechende Kanal
			mit diesem hier verknüpft.<br />
			Die Verknüpfung geschieht automatisch, so dass der Anwender im besten
			Fall nichts davon mitbekommt. Teilweise müssen jedoch Konfigurationsdaten
			gesendet werden.<br />
			In jedem Fall werden diese Verknüpfungen nicht in der WebUI angezeigt.
		</docu>
		
    <link_roles>
      <target name="SWITCH"/>
      <target name="WEATHER_CS"/>
    </link_roles>
		
    <paramset type="MASTER" id="rf_central_ch_listener_master"></paramset>
		<paramset type="LINK" id="rf_central_ch_listener_link"></paramset>

		<enforce_link>
			<value id="LCD_SYMBOL" value="SCENE"/>
			<value id="LCD_LEVEL_INTERP" value="NONE"/>
		</enforce_link>
  </channel>
</channels>
  
<frames>
  <frame id="KEY_SIM_SHORT" direction="to_device" type="0x40" channel_field="9:0.6">
    <parameter type="integer" index="9.6" size="0.1" const_value="0"/>
    <parameter type="integer" index="9.7" size="0.1" const_value="0"/>
    <parameter type="integer" index="10.0" size="1.0" param="SWITCH_COUNTER"/>
  </frame>
  <frame id="KEY_SIM_LONG" direction="to_device" type="0x40" channel_field="9:0.6">
    <parameter type="integer" index="9.6" size="0.1" const_value="1"/>
    <parameter type="integer" index="9.7" size="0.1" const_value="0"/>
    <parameter type="integer" index="10.0" size="1.0" param="SWITCH_COUNTER"/>
  </frame>
  <frame id="SWITCH_LEVEL" direction="to_device" type="0x42" channel_field="9:0.6">
    <parameter type="integer" index="10.0" size="1.0" param="SWITCH_COUNTER"/>
    <parameter type="integer" index="11.0" size="1.0" param="LEVEL"/>
  </frame>
  <frame id="SWITCH_COND" direction="to_device" type="0x41" channel_field="9:0.6">
    <parameter type="integer" index="10.0" size="1.0" param="SWITCH_COUNTER"/>
    <parameter type="integer" index="11.0" size="1.0" param="CONDITION"/>
    <parameter type="integer" index="12.0" size="1.0" const_value="0xff"/>
  </frame>
</frames>

<paramset_defs>
</paramset_defs>
  
</device>
