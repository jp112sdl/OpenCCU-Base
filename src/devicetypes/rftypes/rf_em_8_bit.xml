  <paramset type="MASTER" id="remote_dev_master">
    <parameter id="TRANSMIT_DEV_TRY_MAX">
      <docu default="true"></docu>
      <logical type="integer" min="1.0" max="10.0" default="3.0"/>
      <physical type="integer" interface="config"  list="0" index="20" size="1"/>
    </parameter>
	<parameter id="DEVICE_LED_MODE">
		<docu brief="Modus der Geräte-LED" default="false">
			<p>
				Liefert den aktuellen Modus der Geräte-LED oder legt diesen fest.
			</p>
			<p>
				Es existieren zwei verschiedene Modi für die Geräte-LED:
				<ol start="0">
					<li><i>OFF</i>: Geräte-LED ist deaktiviert (Standard)</li>
					<li><i>ON</i>: Geräte-LED ist aktiviert</li>
				</ol>
			</p>
		</docu>
		<logical type="option">
			<option id="OFF" default="true"/>
			<option id="ON"/>
		</logical>
		<physical type="integer" interface="config" list="0" index="5.6" size="0.2"/>
		<conversion type="integer_integer_map">
			<value_map device_value="0x00" parameter_value="0"/>
			<value_map device_value="0x01" parameter_value="1"/>
		</conversion>
	</parameter>
    <parameter id="LOW_BAT_LIMIT">
      <docu default="false" brief="Schwelle 'Batterie leer'">
        Wenn die Batterie-Spannung unter dem hier gewählten Wert sinkt, wird die Batterie als <i>leer</i> gemeldet.
        Wenn eine Schwelle von 0 V eingestellt ist wird die Batteriewarnung deaktivert.
      </docu>
      <logical type="float" min="0.0" max="12.0" default="0.0" unit="V"/>
      <physical type="integer" interface="config"  list="0" index="18" size="1"/>
      <conversion type="float_integer_scale" factor="10"/>
    </parameter>
    <parameter id="TRANSMIT_DEV_TRY_MAX">
      <docu default="true"></docu>
      <logical type="integer" min="1.0" max="10.0" default="3.0"/>
      <physical type="integer" interface="config"  list="0" index="20" size="1"/>
    </parameter>
    <parameter id="LOCAL_RESET_DISABLE">
        <docu default="false" brief="Sperren des Werksreset am Gerät">
            Sperrt den Werksreset am Gerät
        </docu>
        <logical type="boolean" default="false"/>
        <physical type="integer" interface="config" list="0" index="24" size="0.1"/>
    </parameter>
  </paramset>

