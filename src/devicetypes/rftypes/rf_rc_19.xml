          <logical type="action"/>
          <physical type="integer" interface="store" volatile="true" id="ARROW_DOWN"/>
        </parameter>
        <parameter id="UNIT" operations="write" control="RC19_DISPLAY.UNIT">
          <docu default="false" brief="Anzeige der Einheit">
            Dieser Parameter dient dazu, in Verbindung mit dem Parameter SUBMIT eine Einheit auf dem Display der Fernbedienung anzuzeigen. Zur Auswahl stehen:<br /><br />
            <ol start="0">
              <li>Keine Einheit</li>
              <li>Prozent</li>
              <li>Watt</li>
              <li>Grad Celsius</li>
              <li>Grad Fahrenheit</li>
            </ol>
            <br />
          </docu>
          <logical type="option">
            <option id="NONE" index="0" default="true"/>
            <option id="PERCENT" index="1"/>
            <option id="WATT" index="2"/>        
            <option id="CELSIUS" index="3"/>
            <option id="FAHRENHEIT" index="4"/>
          </logical>
          <physical type="integer" interface="store" volatile="true" id="UNIT"/>
          <conversion type="option_integer">
            <value_map device_value="0x00" parameter_value="0"/>
            <value_map device_value="0x01" parameter_value="1"/>
            <value_map device_value="0x02" parameter_value="2"/>
            <value_map device_value="0x04" parameter_value="3"/>
            <value_map device_value="0x08" parameter_value="4"/>
          </conversion>
        </parameter>
        <parameter id="BEEP" operations="write" control="RC19_DISPLAY.BEEP">
          <docu default="false" brief="Tonausgabe">
             Dieser Parameter dient dazu, in Verbindung mit dem Parameter SUBMIT einen von 3 möglichen Tonfolgen auszugeben. Möglich sind:<br /><br />
            <ol start="0">
              <li>Kein Ton</li>
              <li>Einzelner, gedämpfter Ton</li>
              <li>2 gedämpfte Töne in Folge</li>
              <li>5 laute, kurz hintereinander folgende Töne</li>
            </ol>
            <br />
          </docu>
          <logical type="option">
            <option id="NONE" index="0" default="true"/>
            <option id="TONE1" index="1"/>
            <option id="TONE2" index="2"/>        
            <option id="TONE3" index="3"/>
          </logical>
          <physical type="integer" interface="store" volatile="true" id="BEEP"/>
        </parameter>
        <parameter id="BACKLIGHT" operations="write" control="RC19_DISPLAY.BACKLIGHT">
          <docu default="false" brief="Beleuchtung">
            Mit diesem Parameter kann die Beleuchtung der Fernbedienung aktiviert werden. Dabei stehen verschiedene Möglichkeiten zur Verfügung:<br /><br />
            <ol start="0">
              <li>Beleuchtung AUS</li>
              <li>Beleuchtung EIN</li>
              <li>Beleuchtung langsam blinkend</li>
              <li>Beleuchtung schnell blinkend</li>
            </ol>
            <br />
          </docu>
          <logical type="option">
            <option id="OFF" index="0" default="true"/>
            <option id="ON" index="1"/>
            <option id="BLINK_SLOW" index="2"/>        
            <option id="BLINK_FAST" index="3"/>
          </logical>
          <physical type="integer" interface="store" volatile="true" id="BACKLIGHT"/>
        </parameter>
        <parameter id="SUBMIT" operations="write" control="RC19_DISPLAY.SUBMIT">
          <docu default="false" brief="Displaynachricht übertragen">
            Dieser Parameter dient dazu, die vorher initialisierten Parameter des Parametersatzes VALUE des DISPLAY-Kanals zur Fernbedienung zu übertragen.
			Wenn z. B. ein Text auf dem Display des Gerätes erscheinen soll, muss zuerst der Parameter TEXT mit dem gewünschten Inhalt
			gesetzt werden und dann mittels dem Parameter SUBMIT zur Fernbedienung übertragen werden.
          </docu>
          <logical type="action"/>
          <physical type="integer" interface="command">
            <set request="DISPLAY"/>
            <reset_after_send param="TEXT"/>
            <reset_after_send param="BULB"/>
            <reset_after_send param="SWITCH"/>
            <reset_after_send param="WINDOW"/>
            <reset_after_send param="DOOR"/>
            <reset_after_send param="BLIND"/>
            <reset_after_send param="SCENE"/>
            <reset_after_send param="PHONE"/>
            <reset_after_send param="BELL"/>
            <reset_after_send param="CLOCK"/>
            <reset_after_send param="ARROW_UP"/>
            <reset_after_send param="ARROW_DOWN"/>
            <reset_after_send param="UNIT"/>
            <reset_after_send param="BEEP"/>
            <reset_after_send param="BACKLIGHT"/>
          </physical>
        </parameter>
        <parameter id="ALARM_COUNT" operations="write" control="NONE">
          <docu default="false" brief="Anzeige Anzahl der Alarmmeldungen">Dieser Parameter dient dazu, in Verbindung mit dem Parameter SUBMIT die Anzahl der Alarmmeldungen auf dem Display der Fernbedienung anzuzeigen.</docu>
          <logical type="integer" min="0" max="255"/>
          <physical type="integer" interface="command" value_id="ALARM_COUNT">
            <set request="ALARM_COUNT"/>
          </physical>
        </parameter>
        <parameter id="SERVICE_COUNT" operations="write" control="NONE">
          <docu default="false" brief="Anzeige Anzahl der Servicemeldungen">Dieser Parameter dient dazu, in Verbindung mit dem Parameter SUBMIT die Anzahl der Servicemeldungen auf dem Display der Fernbedienung anzuzeigen.</docu>
          <logical type="integer" min="0" max="255"/>
          <physical type="integer" interface="command" value_id="SERVICE_COUNT">
            <set request="SERVICE_COUNT"/>
          </physical>
        </parameter>
        <parameter id="INSTALL_TEST" operations="write" ui_flags="internal">
          <docu default="true"></docu>
		  <logical type="action"/>
            <physical type="integer" interface="command">
            <set request="INSTALL_TEST"/>
          </physical>
        </parameter>
      </paramset>
